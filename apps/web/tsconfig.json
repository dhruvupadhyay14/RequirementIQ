{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@ui/*": ["../../packages/ui/src/*"],
      "@types/*": ["../../packages/shared-types/*"]
    }
  },
  "include": ["src"]
}
